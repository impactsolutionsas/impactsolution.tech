# Postgres — dev local (docker-compose) : postgres://postgres:postgres@127.0.0.1:5432/payload
# Postgres — Supabase : utiliser la connection string du pooler (Session ou Transaction mode),
# pas la connexion directe, pour éviter l'épuisement de connexions en prod.
DATABASE_URI=postgres://postgres:postgres@127.0.0.1:5432/payload

# Générer avec: openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# URL publique du front Next.js (web/), utilisée pour le live preview (LOT 2)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- LOT 3 (Media & Storage Supabase) — pas encore utilisées ---
# SUPABASE_STORAGE_ENDPOINT=
# SUPABASE_STORAGE_BUCKET_PUBLIC=media-public
# SUPABASE_STORAGE_BUCKET_PRIVATE=media-private
# SUPABASE_STORAGE_ACCESS_KEY_ID=
# SUPABASE_STORAGE_SECRET_ACCESS_KEY=

# --- LOT 4 (revalidation front) — pas encore utilisée ---
# REVALIDATE_SECRET=
